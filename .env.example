# Gemini API キー（https://aistudio.google.com/apikey で取得）
GEMINI_API_KEY=your_api_key_here

# 使用する画像生成モデル（変更可能）
GEMINI_MODEL=gemini-3.1-flash-image

# pptx書き出し時の文字抽出に使うテキスト/ビジョンモデル（変更可能）
GEMINI_TEXT_MODEL=gemini-2.5-flash

# サーバーのポート
PORT=3000

# 制作途中ページの保存先フォルダ（未指定なら banner-generator の隣に banner-projects を自動作成）
# 例: D:\★★トレジャートウキョウ\banner-projects
# PROJECTS_DIR=
